<?xml version="1.0" encoding="UTF-8" ?>
<odoo>


<record id="subject_selection_form_view" model="ir.ui.view">
    <field name="name">subject.selection.form.view</field>
    <field name="model">college.subject.selection</field>
    <field name="arch" type="xml">
       <form>
           <sheet>
               <group>
                    <field name="target_teacher_id" invisible="1"/>
                    <field name="subject_id"/>
                    <field name="teachers_id"/>
                    <field name="students_ids" widget="many2many_tags"/>
               </group>
           </sheet>
       </form>
    </field>
</record>





<record id="subject_selection_view_tree" model="ir.ui.view">
    <field name="name">subject.selection.tree.view</field>
    <field name="model">college.subject.selection</field>
    <field name="arch" type="xml">
        <list>
          <field name="subject_id"/>
          <field name="teachers_id"/>
          <field name="students_ids"/>
        </list>
    </field>
</record>


<record id="action_subject_selection" model="ir.actions.act_window">
    <field name="name">საგნის არჩევა</field>
    <field name="res_model">college.subject.selection</field>
    <field name="view_mode">list,form</field>
</record>

<menuitem id="menu_student_subjects"
          name="საგნების არჩევა"
          parent="menu_college_erp_root"
          action="action_subject_selection"
          sequence="5"/>
</odoo>