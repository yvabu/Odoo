<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="teacher_dashboard" name="მასწავლებლის Dashboard">
        <t t-call="website.layout">
            <style>
                .s_dashboard_main {
                    background-color: #f8faff;
                    padding-top: 50px;
                    padding-bottom: 80px;
                    min-height: 100vh;
                }

                /* ლექტორის პროფილის ბარათი - უფრო დიდი და სუფთა */
                .profile-card {
                    background: #ffffff;
                    border-radius: 24px !important;
                    border: 1px solid #eef2f7;
                    position: sticky;
                    top: 30px;
                    padding: 40px 30px !important;
                }

                .profile-avatar-circle {
                    width: 100px;
                    height: 100px;
                    background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
                    margin: 0 auto 20px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    box-shadow: 0 10px 25px rgba(79, 70, 229, 0.2);
                }

                /* ძებნის ველი */
                #subjectSearch {
                    border-radius: 16px;
                    border: 2px solid #e2e8f0;
                    padding: 15px 20px 15px 50px;
                    font-size: 1.1rem;
                    background-color: white;
                }

                /* საგნის ქარდი - გაზრდილი ზომებით */
                .uni-course-card {
                    background: #ffffff;
                    border-radius: 24px !important;
                    border: 1px solid #eef2f7;
                    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
                    height: 100%;
                    min-height: 280px; /* მინიმალური სიმაღლე გაიზარდა */
                }

                .uni-course-card:hover {
                    transform: translateY(-10px);
                    box-shadow: 0 30px 60px -12px rgba(50, 50, 93, 0.15) !important;
                    border-color: #4f46e5;
                }

                .card-accent-pill {
                    height: 6px;
                    width: 60px;
                    background: #4f46e5;
                    border-radius: 20px;
                    margin-bottom: 25px;
                }

                .course-title {
                    color: #1e293b;
                    font-weight: 800;
                    font-size: 1.4rem; /* უფრო დიდი სათაური */
                    line-height: 1.3;
                    margin-bottom: 15px;
                }

                /* სტუდენტების თეგი */
                .stu-tag {
                    background-color: #eff6ff;
                    color: #1e40af;
                    padding: 8px 16px;
                    border-radius: 12px;
                    font-weight: 700;
                    font-size: 0.95rem;
                }

                /* მთავარი ღილაკი - უფრო დიდი */
                .btn-uni-large {
                    background-color: #ffffff;
                    border: 2px solid #e2e8f0;
                    color: #475569;
                    border-radius: 16px;
                    font-weight: 700;
                    padding: 14px;
                    font-size: 1.1rem;
                    transition: all 0.3s;
                    display: block;
                    text-align: center;
                    text-decoration: none !important;
                }

                .btn-uni-large:hover {
                    background-color: #4f46e5;
                    border-color: #4f46e5;
                    color: white !important;
                }
            </style>

            <div class="s_dashboard_main">
                <div class="container">
                    <div class="row">
                        <div class="col-lg-3 col-md-4 mb-4">
                            <div class="card border-0 shadow-sm profile-card text-center">
                                <div class="profile-avatar-circle rounded-circle text-white">
                                    <i class="fa fa-user-tie fa-3x"></i>
                                </div>
                                <h3 class="font-weight-bold mb-1" style="color: #0f172a;">
                                    <t t-out="teacher.name"/> <t t-out="teacher.last_name"/>
                                </h3>
                                <p class="text-primary font-weight-bold small text-uppercase mb-4">უნივერსიტეტის ლექტორი</p>
                                <div class="text-left border-top pt-4">
                                    <p class="small text-muted mb-2"><i class="fa fa-envelope mr-2"/> <t t-out="teacher.email"/></p>
                                    <p class="small text-muted mb-0"><i class="fa fa-university mr-2"/> აკადემიური პერსონალი</p>
                                </div>
                        </div>
                        <div class="col-lg-9 col-md-8">
                            <div class="row align-items-center mb-5">
                                <div class="col-md-5">
                                    <h2 class="font-weight-bold mb-0" style="color: #0f172a; font-size: 2.2rem;">ჩემი საგნები</h2>
                                </div>
                                <div class="col-md-7 mt-3 mt-md-0">
                                    <div class="search-container">
                                        <i class="fa fa-search position-absolute" style="left: 20px; top: 18px; color: #94a3b8; font-size: 1.2rem;"></i>
                                        <input type="text" id="subjectSearch" class="form-control w-100" placeholder="მოძებნეთ კურსი დასახელებით..."/>
                                    </div>
                                </div>
                            </div>

                            <div class="row" id="subjectList">
                                <t t-foreach="subjects" t-as="sub">
                                    <div class="col-xl-4 col-lg-6 mb-4 subject-item">
                                        <div class="card uni-course-card shadow-sm p-4 border-0">
                                            <div class="card-body p-0 d-flex flex-column">
                                                <div class="card-accent-pill"></div>
                                                <h4 class="course-title">
                                                    <t t-esc="sub.subject_name"/>
                                                </h4>
                                                <div class="mb-4 mt-2">
                                                    <span class="stu-tag">
                                                        <i class="fa fa-users-class mr-2"></i>
                                                        <t t-esc="len(sub.student_ids)"/> სტუდენტი
                                                    </span>
                                                </div>
                                                <div class="mt-auto pt-3">
                                                    <a t-attf-href="/teacher/subject/#{sub.id}" class="btn-uni-large">
                                                        მართვა <i class="fa fa-arrow-right ml-2 small"></i>
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </t>
                            </div>

                            <div id="noResults" class="text-center mt-5 d-none py-5">
                                <div class="bg-white d-inline-block p-5 rounded-circle shadow-sm mb-4">
                                    <i class="fa fa-search fa-3x text-muted opacity-25"></i>
                                </div>
                                <h4 class="text-muted">მსგავსი საგანი ვერ მოიძებნა</h4>
                            </div>
                        </div>
                    </div>
                </div>
                </div>
            </div>
            <script type="text/javascript">
                document.getElementById('subjectSearch').addEventListener('keyup', function() {
                    let filter = this.value.toLowerCase();
                    let items = document.querySelectorAll('.subject-item');
                    let found = false;

                    items.forEach(function(item) {
                        let title = item.querySelector('.course-title').innerText.toLowerCase();
                        if (title.includes(filter)) {
                            item.style.display = 'block';
                            found = true;
                        } else {
                            item.style.display = 'none';
                        }
                    });

                    document.getElementById('noResults').classList.toggle('d-none', found);
                });
            </script>
        </t>
    </template>
</odoo>