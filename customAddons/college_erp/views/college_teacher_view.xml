<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>

        <record id="college_teacher_tree_view" model="ir.ui.view">
            <field name="name">college.teacher.tree.view</field>
            <field name="model">college.teacher</field>
            <field name="arch" type="xml">
                <list>
                    <field name="last_name"/>
                    <field name="email"/>
                    <field name="user_id"/>
                    <field name="subject_ids"/>
                </list>
            </field>

        </record>



        <record id="view_college_teacher_form_custom" model="ir.ui.view">
            <field name="name">college.teacher.form.custom</field>
            <field name="model">college.teacher</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="user_id"/>
                            <field name="name"/>
                            <field name="last_name"/>
                            <field name="email"/>
                        </group>
                        <notebook>
                            <page string="ჩემი საგნები">
                                <field name="subject_ids"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_college_teacher" model="ir.actions.act_window">
            <field name="name">მასწავლებელი</field>
            <field name="res_model">college.teacher</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_group_by_subject': 1}</field>
        </record>

        <menuitem id="menu_college_for_teacher"
                  name="მასწავლებელი"
                  parent="menu_college_erp_root"
                  action="action_college_teacher"
                  sequence="4"
                  groups="college_erp.group_college_erp_teacher,base.group_system"/>

    </data>
</odoo>